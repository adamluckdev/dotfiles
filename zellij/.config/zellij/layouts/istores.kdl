layout {
    default_tab_template {
        // the default zellij tab-bar and status bar plugins
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        children
        pane size=2 borderless=true {
            plugin location="zellij:status-bar"
        }
    }
    tab name="general"
    tab name="backend" cwd="$HOME/Projects/gitlab_wdev/ecommerce/istores/backend"
    tab name="import" cwd="$HOME/Projects/gitlab_wdev/ecommerce/istores/backend"
    tab name="cms" cwd="$HOME/Projects/gitlab_wdev/ecommerce/istores/cms"
    tab name="frontend" cwd="$HOME/Projects/gitlab_wdev/ecommerce/istores/frontend"
    tab name="db" cwd="$HOME/Projects/gitlab_wdev/ecommerce/istores/backend"
    tab name="tunnels" cwd="$HOME/.ssh"
}
